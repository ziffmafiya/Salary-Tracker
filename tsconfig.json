{
    "compilerOptions": {
        "target": "es2020",
        "module": "es2020",
        "moduleResolution": "bundler",
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": false,
        "sourceMap": false,
        "noEmit": false
    },
    "include": ["src"]
}
